{
  "manifest_version": 3,
  "name": "Recon",
  "version": "0.9.19",
  "description": "Email intelligence — open tracking for Gmail",
  "permissions": ["activeTab", "storage", "scripting", "alarms", "notifications"],
  "host_permissions": [
    "https://mail.google.com/*",
    "https://recon.vaidikedu.com/*",
    "https://*.vaidikedu.com/*",
    "http://localhost:8000/*",
    "http://127.0.0.1:8000/*",
    "https://localhost:8000/*",
    "https://127.0.0.1:8000/*"
  ],
  "background": {
    "service_worker": "service-worker.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/icon16.png"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
